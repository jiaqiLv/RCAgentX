# OpenAI API Key (or other LLM provider)
OPENAI_API_KEY=your-api-key-here

# LLM Configuration
# DeepSeek
LLM_MODEL=deepseek-chat
OPENAI_API_BASE=https://api.deepseek.com/v1

# OpenAI
# LLM_MODEL=gpt-4o
# OPENAI_API_BASE=https://api.openai.com/v1

# Prometheus Configuration
PROMETHEUS_URL=http://localhost:9090

# Loki Configuration
LOKI_URL=http://localhost:3100

# Alertmanager Configuration
# ALERTMANAGER_URL=http://localhost:9093

# Enterprise WeChat Configuration
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# WECHAT_SECRET=xxx

# Agent Configuration
# VERBOSE=false
# DRY_RUN=false

# Mock Data Configuration (for testing without real monitoring)
# Set MOCK_ENABLED=true to use generated mock data instead of real Prometheus/Loki
MOCK_ENABLED=true
MOCK_ANOMALY_TYPE=cpu
# MOCK_ANOMALY_TYPE values: cpu, memory, latency, error, or None for mixed
# MOCK_SEED=42
